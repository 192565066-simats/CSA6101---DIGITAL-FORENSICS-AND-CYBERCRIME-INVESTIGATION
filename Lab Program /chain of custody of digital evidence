import hashlib

file_name = "evidence.txt"

# Create a sample evidence file
with open(file_name, "w") as file:
    file.write("This is digital evidence.")

# Function to calculate SHA-256 hash
def calculate_hash(file):
    sha256 = hashlib.sha256()
    with open(file, "rb") as f:
        while chunk := f.read(4096):
            sha256.update(chunk)
    return sha256.hexdigest()

# Original hash
original_hash = calculate_hash(file_name)
print("Original Hash:")
print(original_hash)

# Verify integrity
current_hash = calculate_hash(file_name)

print("\nVerification Result:")
if original_hash == current_hash:
    print("Chain of Custody Verified: File is unchanged.")
else:
    print("Chain of Custody Failed: File has been modified.")

